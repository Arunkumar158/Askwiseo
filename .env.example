# Frontend (Vercel Environment Variables)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# FastAPI backend URL for browser API calls
NEXT_PUBLIC_API_URL=https://askwiseo-backend.onrender.com

# Optional: same-origin /api/* rewrite target for server-side or local fallback
API_PROXY_URL=https://askwiseo-backend.onrender.com

# Backend (Render)
ALLOWED_ORIGINS=["http://localhost:3000","https://askwiseo.vercel.app"]
FRONTEND_URL=https://askwiseo.vercel.app
GEMINI_API_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
